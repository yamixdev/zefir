# Конфигурация Telegram Agent Bot
# Скопируйте этот файл в .env и заполните значения

# Обязательные переменные
BOT_TOKEN=your_telegram_bot_token_here_from_BotFather

# Опциональные переменные (рекомендуется настроить)
ADMIN_ID=your_telegram_user_id_here
YANDEX_WEATHER_API_KEY=your_yandex_weather_api_key_here

# Как получить значения:
#
# 1. BOT_TOKEN:
#    - Откройте @BotFather в Telegram
#    - Используйте команду /newbot
#    - Следуйте инструкциям для создания бота
#    - Скопируйте полученный токен
#
# 2. ADMIN_ID:
#    - Откройте @userinfobot в Telegram
#    - Отправьте любое сообщение
#    - Бот ответит с вашим ID
#    - Скопируйте значение "Id"
#
# 3. YANDEX_WEATHER_API_KEY:
#    - Зарегистрируйтесь на https://developer.tech.yandex.ru/
#    - Создайте новый ключ для API Яндекс.Погоды
#    - Скопируйте полученный ключ
#
# Примечание: В Yandex Cloud Functions эти переменные настраиваются
# через параметр ENVIRONMENT в CI/CD конфигурации