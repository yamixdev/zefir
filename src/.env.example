# Пример переменных окружения для Yandex Cloud Function
# Скопируйте этот файл в .env и заполните реальными значениями
# НЕ КОММИТЬТЕ .env ФАЙЛ В GIT!

# Обязательные переменные
API_KEY=your_api_key_here

# Опциональные переменные
SECRET_TOKEN=your_secret_token_here
DEBUG_MODE=false
ADMIN_ID=123456789

# Дополнительные переменные (примеры)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
REDIS_URL=redis://localhost:6379
JWT_SECRET=your_jwt_secret_here
LOG_LEVEL=info

# Как использовать в коде:
# const API_KEY = process.env.API_KEY;
# const DEBUG_MODE = process.env.DEBUG_MODE === 'true';

# В Yandex Cloud Functions переменные окружения настраиваются:
# 1. Через интерфейс Yandex Cloud Console
# 2. Через параметр ENVIRONMENT в CI/CD конфигурации
# 3. Через yc CLI: yc serverless function set-environment

# Формат для Yandex Cloud:
# KEY1=value1,KEY2=value2,KEY3=value3